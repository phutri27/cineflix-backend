// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(uuid())
  hashed_password String?    @db.VarChar(1080)
  email           String    @unique @db.VarChar(255)
  first_name      String?   @db.VarChar(255)
  last_name       String?   @db.VarChar(255)
  role            Role      @default(USER)

  thirdParty      ThirdParty[]
  profile         Profile?
  bookings        Booking[]
}

model ThirdParty{
  id                  String       @id @default(uuid())
  userId              String       
  provider            AuthProvider 
  providerAccountId   String       

  user                User         @relation(fields: [userId], references: [id])
  @@unique([providerAccountId, provider])
}


model Profile {
  spending_total Decimal @default(0) @db.Decimal(10, 2)
  member_rank    String  @default("copper")
  
  userId         String  @id
  user           User    @relation(fields: [userId], references: [id])
}

model Movie {
  id             String   @id @default(uuid())
  title          String
  plot           String   @db.Text
  posterUrl      String
  posterPublicId String
  durationMin    Int
  premiereDate   DateTime
  rated          String

  cinemas      Cinema[]
  bookings     Booking[]
  genres       Genre[]
  directors    Director[]
  actors       Actor[]
  showtimes    Showtime[]
}

model Genre {
  id     String       @id @default(uuid())
  name   String       @unique
  movies Movie[]
}

model Director {
  id     String          @id @default(uuid())
  name   String
  movies Movie[]
}

model Actor {
  id     String       @id @default(uuid())
  name   String
  movies Movie[]
}

model City {
  id      Int      @id @default(autoincrement())
  name    String
  cinemas Cinema[]
}

model Cinema {
  id      String   @id @default(uuid())
  name    String
  cityId  Int
  address String
  hotline String
  city    City     @relation(fields: [cityId], references: [id])
  
  seatType SeatTypeDetail[]
  movies  Movie[]
  screens Screen[]
}

model Screen {
  id        String     @id @default(uuid())
  name      String
  cinemaId  String
  cinema    Cinema     @relation(fields: [cinemaId], references: [id])
  
  seats     Seat[]
  showtimes Showtime[]
}

model Seat {
  id              String   @id @default(uuid())
  row             String
  number          Int

  seat_typeId     String
  seatTypeDetail  SeatTypeDetail @relation(fields: [seat_typeId], references: [id])
  
  screenId        String
  screen          Screen @relation(fields: [screenId], references: [id])
  tickets         Ticket[]
}

model Showtime {
  id        String   @id @default(uuid())
  startTime DateTime
  
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id])
  
  screenId  String
  screen    Screen   @relation(fields: [screenId], references: [id])

  bookings  Booking[]
  tickets   Ticket[]
}

model Booking {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])

  movieId       String
  movie         Movie          @relation(fields: [movieId], references: [id])
  
  showtimeId    String
  showtime      Showtime       @relation(fields: [showtimeId], references: [id])
  
  status        BookingStatus  @default(PENDING)
  totalAmount   Decimal        @db.Decimal(10, 2)
  bankReference String?        @unique 
  createdAt     DateTime       @default(now())

  vouchers      BookingVoucher[]
  tickets       Ticket[]
  snacks        BookingSnack[]
}

model Voucher {
  id             String   @id @default(uuid())
  name           String
  reduceAmount   Float     
  startAt        DateTime
  expireAt       DateTime
  activationCode String   @unique

  bookings       BookingVoucher[]
}

model BookingVoucher {
  bookingId  String 
  booking   Booking @relation(fields: [bookingId], references: [id])

  voucherId String
  voucher   Voucher @relation(fields: [voucherId], references: [id])

  quantity  Int     @default(1)
  @@id([bookingId, voucherId])
}

model SeatTypeDetail{
  id        String  @id @default(uuid())
  price     Decimal @db.Decimal(10, 2)
  seat_type String

  seats     Seat[]

  cinemaId  String
  cinema    Cinema  @relation(fields: [cinemaId], references: [id], onDelete: Cascade)

  @@unique([seat_type, cinemaId])
}

model Ticket {
  id         String   @id @default(uuid())
  
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id])
  
  seatId     String
  seat       Seat     @relation(fields: [seatId], references: [id])
  
  showtimeId String
  showtime   Showtime @relation(fields: [showtimeId], references: [id])

  @@unique([showtimeId, seatId]) 
}

model Snack {
  id            String         @id @default(uuid())
  name          String
  price         Decimal        @db.Decimal(10, 2)
  imageUrl      String?
  imagePublicId String

  bookings BookingSnack[]
}

model BookingSnack {
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])
  
  snackId   String
  snack     Snack   @relation(fields: [snackId], references: [id])
  
  quantity  Int     @default(1)

  @@id([bookingId, snackId])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  FAILED
  CANCELLED
}

enum Role{
  ADMIN
  USER
  GUEST
}

enum AuthProvider{
  LOCAL
  GOOGLE
}