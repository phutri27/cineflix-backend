// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(uuid())
  hashed_password String?    @db.VarChar(1080)
  email           String    @unique @db.VarChar(255)
  first_name      String?   @db.VarChar(255)
  last_name       String?   @db.VarChar(255)
  role            Role      @default(USER)

  thirdParty      ThirdParty[]
  profile         Profile?
  bookings        Booking[]
  notifications   Notifications[]
}

model ThirdParty{
  id                  String       @id @default(uuid())
  userId              String       
  provider            AuthProvider 
  providerAccountId   String       

  user                User         @relation(fields: [userId], references: [id])
  @@unique([providerAccountId, provider])
}


model Profile {
  spending_total Decimal @default(0) @db.Decimal(10, 2)
  member_rank    String  @default("copper")
  
  userId         String  @id
  user           User    @relation(fields: [userId], references: [id])

  vouchers        ProfileVoucher[]
}

model Movie {
  id             String   @id @default(uuid())
  title          String
  plot           String   @db.Text
  posterUrl      String
  posterPublicId String
  durationMin    Int
  premiereDate   DateTime
  rated          String
  trailerUrl     String?
  isActive      Boolean  @default(true)

  cinemas      Cinema[]
  genres       Genre[]
  directors    Director[]
  actors       Actor[]
  showtimes    Showtime[]
}

model Genre {
  id     String       @id @default(uuid())
  name   String       @unique
  createdAt DateTime @default(now())
  movies Movie[]
}

model Director {
  id     String          @id @default(uuid())
  name   String
  createdAt DateTime @default(now())
  movies Movie[]
}

model Actor {
  id     String       @id @default(uuid())
  name   String
  createdAt DateTime @default(now())
  movies Movie[]
}

model City {
  id      Int      @id @default(autoincrement())
  name    String
  cinemas Cinema[]
}

model Cinema {
  id        String   @id @default(uuid())
  name      String
  cityId    Int
  address   String
  hotline   String
  createdAt DateTime @default(now())
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  
  seatType SeatTypeDetail[]
  movies  Movie[]
  screens Screen[]
}

model Screen {
  id        String     @id @default(uuid())
  name      String
  createdAt DateTime   @default(now())
  cinemaId  String
  cinema    Cinema     @relation(fields: [cinemaId], references: [id], onDelete: Cascade)
  
  seats     Seat[]
  showtimes Showtime[]
}

model Seat {
  id              String   @id @default(uuid())
  row             String
  number          Int

  seat_typeId     String
  seatTypeDetail  SeatTypeDetail @relation(fields: [seat_typeId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  
  screenId        String
  screen          Screen @relation(fields: [screenId], references: [id])
  tickets         Ticket[]
  bookings        Booking[]

  @@unique([screenId, row, number])
}

model Showtime {
  id        String   @id @default(uuid())
  startTime DateTime
  
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: NoAction)
  
  screenId  String
  screen    Screen   @relation(fields: [screenId], references: [id], onDelete: Cascade)

  isCancelled Boolean @default(false)

  bookings  Booking[]

}

model Notifications{
  id    String @id @default(uuid())
  title String
  createdAt DateTime @default(now())
  content String
  readStatus Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Booking {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  
  showtimeId      String
  showtime        Showtime       @relation(fields: [showtimeId], references: [id], onDelete: NoAction)
  createdAt       DateTime       @default(now())
  status          BookingStatus   @default(PENDING)

  seats         Seat[]         
  vouchers      BookingVoucher[]
  tickets       Ticket[]
  snacks        BookingSnack[]
  transaction   Transaction[]
}

model Transaction {
  id            String   @id @default(uuid())
  bookingId     String
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  provider             String
  providerTransactionId String?
  amount               Decimal  @db.Decimal(10, 2)
  currency      String   @default("VND")

  status        TransactionStatus @default(PENDING)
  transactionAt DateTime @default(now())
}

model Voucher {
  id             String   @id @default(uuid())
  name           String
  reduceAmount   Float     
  createdAt      DateTime @default(now())
  quantity       Int
  startAt        DateTime
  expireAt       DateTime
  activationCode String   @unique
  maxUsed        Int      

  bookings       BookingVoucher[]
  profiles       ProfileVoucher[]
}

model BookingVoucher {
  bookingId  String 
  booking   Booking @relation(fields: [bookingId], references: [id])

  voucherId String
  voucher   Voucher @relation(fields: [voucherId], references: [id])

  quantity  Int     @default(1)
  @@id([bookingId, voucherId])
}

model ProfileVoucher{
  userId         String
  user           Profile     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  voucherId      String
  voucher        Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  quantity        Int      @default(1)
  @@id([userId, voucherId])
}

model SeatTypeDetail{
  id        String  @id @default(uuid())
  price     Decimal @db.Decimal(10, 2)
  seat_type String

  createdAt DateTime @default(now())
  seats     Seat[]

  cinemaId  String
  cinema    Cinema  @relation(fields: [cinemaId], references: [id], onDelete: Cascade)

  @@unique([seat_type, cinemaId])
}

model Ticket {
  id         String   @id @default(uuid())
  
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id])
  
  seatId     String
  seat       Seat     @relation(fields: [seatId], references: [id], onUpdate: Cascade)

  ticketUrl  String? 
}

model Snack {
  id            String         @id @default(uuid())
  name          String
  price         Decimal        @db.Decimal(10, 2)
  imageUrl      String?
  imagePublicId String
  createdAt     DateTime       @default(now())

  bookings BookingSnack[]
}

model BookingSnack {
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  snackId   String
  snack     Snack   @relation(fields: [snackId], references: [id], onDelete: Cascade)
  
  quantity  Int     @default(1)

  @@id([bookingId, snackId])
}

enum BookingStatus {
  PENDING
  PAID
  CANCELLED
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum Role{
  ADMIN
  USER
  GUEST
}

enum AuthProvider{
  LOCAL
  GOOGLE
}
